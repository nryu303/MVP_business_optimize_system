{
  "name": "mvp-business-optimize-system",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:admin": "npm run dev --workspace=@mvp/admin",
    "dev:lp": "npm run dev --workspace=@mvp/lp",
    "dev:worker": "npm run dev --workspace=@mvp/worker",
    "dev": "concurrently -n admin,lp,worker -c blue,green,magenta \"npm:dev:admin\" \"npm:dev:lp\" \"npm:dev:worker\"",
    "build": "npm run build --workspaces --if-present",
    "db:generate": "npm run generate --workspace=@mvp/db",
    "db:migrate": "npm run migrate --workspace=@mvp/db",
    "db:push": "npm run db:push --workspace=@mvp/db",
    "db:studio": "npm run studio --workspace=@mvp/db",
    "db:seed": "npm run seed --workspace=@mvp/db",
    "start:admin": "npm run start --workspace=@mvp/admin",
    "start:lp":    "npm run start --workspace=@mvp/lp",
    "start":       "concurrently -n admin,lp -c blue,green \"npm:start:admin\" \"npm:start:lp\""


  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
